# FDE solution — local development configuration.
#
# Copy this file to `.env` (in py/ or py/apps/sample/) and fill in your Azure OpenAI
# details. `.env` is gitignored — never commit real secrets. In production these are
# supplied as real environment variables by the host / Key Vault.

# --- Azure OpenAI connection (required for live model calls) ---
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_API_VERSION=2024-10-21

# --- Deployments ---
# Primary (multimodal) deployment used for triage + orchestrate, and for extract
# unless AOAI_VISION_DEPLOYMENT is set. A small reasoning model (e.g. gpt-5.4-mini)
# scores best on the benchmark's efficiency/cost dimension.
AOAI_DEPLOYMENT=gpt-5.4-mini

# Optional: separate vision-capable deployment for /extract. Leave blank to reuse
# AOAI_DEPLOYMENT (fine when it is already multimodal, like gpt-5.4-mini).
AOAI_VISION_DEPLOYMENT=

# Reported in the X-Model-Name response header for the platform's cost scoring.
# Set this to the model you actually call.
MODEL_NAME=gpt-5.4-mini

# --- Resilience / efficiency knobs (optional; sensible defaults shown) ---
REQUEST_TIMEOUT_S=25
MAX_RETRIES=1
RETRY_BASE_DELAY_S=1.0
MAX_CONCURRENCY=8
LLM_TEMPERATURE=0.0
# Reasoning-model effort (o-series / GPT-5 only; ignored by standard models).
# minimal | low | medium | high.
REASONING_EFFORT=minimal
TRIAGE_REASONING_EFFORT=minimal
VISION_REASONING_EFFORT=low
ORCHESTRATE_REASONING_EFFORT=medium
